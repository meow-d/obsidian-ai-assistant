{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "verbatimModuleSyntax": true,
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "paths": {
      "onnxruntime-web": ["./node_modules/onnxruntime-web/types.d.ts"]
    }
  },
  "include": ["**/*.ts"]
}
